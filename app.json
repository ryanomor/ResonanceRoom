{
  "expo": {
    "name": "Venn",
    "slug": "venn-app",
    "version": "1.90.0",
    "orientation": "portrait",
    "icon": "./assets/icons/venn_icon.png",
    "scheme": "venn-app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundImage": "./assets/icons/venn_icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.venn.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundImage": "./assets/icons/venn_icon.png"
      },
      "package": "com.venn.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
