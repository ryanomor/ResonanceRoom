{
  "expo": {
    "name": "EchoMatch",
    "slug": "echomatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/dreamflow_icon.jpg",
    "scheme": "echomatch",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icons/dreamflow_icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#13111C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.echomatch.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/dreamflow_icon.jpg",
        "backgroundColor": "#13111C"
      },
      "package": "com.echomatch.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/dreamflow_icon.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
